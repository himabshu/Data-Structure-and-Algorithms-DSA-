class Solution {
    int row=0,col=-3;
    public boolean isValidSudoku(char[][] board) {
      for(int i=0;i<9;i++){
        if(col==6){
            row=row+3;
            col=0;
        }else{
            col=col+3;
        }
        boolean flag = isValid(board,row,col);
        if(!flag){
            return false;
        }
        flag = isValid(board);
        if(!flag) return false;
      }
      return true;
    }

    private boolean isValid(char[][] arr){
        char arrT[][] = new char[9][9];
        for(int i=0;i<9;i++){
            for(int j=0;j<9;j++){
              arrT[i][j]=arr[j][i];
            }
        }
        for(int i=0;i<9;i++){
            boolean row[] = new boolean[10];
            boolean col[] = new boolean[10];
            for(int j=0;j<9;j++){
                if(arr[i][j] != '.'){
                int val = arr[i][j]-'0';
                if(row[val]==false){
                    row[val]=true;
                }else{
                    return false;
                }
              }
              if(arrT[i][j] != '.'){
                int val = arrT[i][j]-'0';
                if(col[val]==false){
                    col[val]=true;
                }else{
                    return false;
                }
                }
            }
        }
        return true;
    }

    private boolean isValid(char[][] arr , int row,int col){
        boolean dp[] = new boolean[10];
        for(int i=row;i<row+3;i++){
            for(int j=col;j<col+3;j++){
                if(arr[i][j] != '.'){
                int val = arr[i][j]-'0';
                if(dp[val]==false){
                    dp[val]=true;
                }else{
                    return false;
                }}
            }
        }
        return true;
    }
}
